BOT_TOKEN=123456:telegram-bot-token
TELEGRAM_API_BASE_URL=
TELEGRAM_PROXY_URL=
TELEGRAM_PROXY_FILE=proxies.txt
TELEGRAM_REQUEST_TIMEOUT=10
POLLING_RETRY_DELAY=2

# Groq settings (disguised as DeepSeek for users)
GROQ_API_KEY=gsk_your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_BASE_URL=https://api.groq.com/openai/v1
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.95
LLM_MAX_TOKENS=8192

# Local runtime settings.
DATABASE_PATH=storage/bot.sqlite3
MAX_CONTEXT_MESSAGES=40
MAX_REPLY_CHARS=3500

# In group chats the bot answers when mentioned, replied to, or via /ask.
ANSWER_ON_EVERY_MESSAGE=false
